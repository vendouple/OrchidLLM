# Oracle DB Connection (TLS - no wallet required)
# Use separate credentials for Oracle Cloud Autonomous DB
ORACLE_DB_USER=ADMIN
ORACLE_DB_PASSWORD=YourSuperSecretPassword123!
ORACLE_DB_CONNECTION_STRING=ORACLEDB STRING

# Alternative: Legacy variable names
# ORACLE_USER=your_username
# ORACLE_PASSWORD=your_password
# ORACLE_CONNECT_STRING=host:port/service_name

# API Keys for External Services
POLLINATIONS_API_KEY=pl_xxxxxxxxxxxx
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxx

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
BASE_URL=https://orchidllm.vercel.app

# Session Secret
SESSION_SECRET=your_random_session_secret_here

# Vercel URL (auto-set by Vercel)
# VERCEL_URL=orchidllm.vercel.app