# Pollinations API Key (for demo mode)
POLLINATIONS_API_KEY=pl_your_pollinations_key_here

# NVIDIA NIM API Key
NVIDIA_API_KEY=nvapi_your_nvidia_key_here

# PlanetScale Database URL (for global API key management)
DATABASE_URL=mysql://user:password@host/database

# Upstash Redis (via Vercel Redis integration)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# GitHub OAuth (for admin login)
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
